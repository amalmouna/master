# Copier en .env.local (ignoré par git) et renseigner les vraies valeurs.
# Voir docs/AUTH_SETUP.md pour le contexte complet (architecture privée/authentifiée).

# Clé anon uniquement — jamais service_role ici (réservé au loader Python,
# src/persistence/load_to_supabase.py, exécuté en local/CI, jamais sur Vercel).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL du backend d'import (Render, backend/) — le navigateur envoie les
# fichiers .xlsx DIRECTEMENT à cette URL (jamais proxié par Vercel), avec le
# token Supabase de l'admin connecté. Publique par nature (visible dans le
# bundle client) : ce n'est qu'une URL de service, pas un secret — la
# vérification d'accès admin se fait côté backend (voir backend/app/auth.py).
NEXT_PUBLIC_IMPORT_API_URL=
