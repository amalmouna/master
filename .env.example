# Copier en .env.local (ignoré par git) et renseigner les vraies valeurs.
# Ne jamais committer de vraies clés.

# --- Pipeline Python (pseudonymisation) ---
# Sel HMAC pour la pseudonymisation des codes élèves (étape C). Si absent, un
# sel local est généré et persisté hors dépôt (data/artifacts/.salt).
MASSAR_SALT=

# --- Chargement vers Supabase (loader Python, src/persistence/) ---
# Clé service_role : donne un accès complet en écriture, contourne RLS.
# Utilisée UNIQUEMENT par le loader Python, jamais côté frontend/navigateur.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Frontend Next.js (frontend/.env.local — variables séparées du .env.local racine) ---
# Clé anon : la seule autorisée côté navigateur. Depuis l'architecture privée/
# authentifiée (docs/AUTH_SETUP.md), l'accès aux données dépend de la session
# utilisateur (RLS admin-only), pas du niveau de privilège de cette clé.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
