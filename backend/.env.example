# Copier en backend/.env.local (ignoré par git) et renseigner les vraies valeurs.
# Ne jamais committer de vraies clés.

# --- Supabase ---
# URL du projet, commune aux deux clés ci-dessous.
SUPABASE_URL=
# Clé anon : utilisée UNIQUEMENT pour vérifier le token de l'appelant
# (GET /auth/v1/user puis RPC is_admin()) — jamais pour écrire des données.
SUPABASE_ANON_KEY=
# Clé service_role : écrit les résultats de l'import, contourne RLS. Jamais
# exposée au frontend/navigateur — usage serveur exclusif, comme le loader
# CLI (src/persistence/load_to_supabase.py).
SUPABASE_SERVICE_ROLE_KEY=

# --- Pseudonymisation (score_import.run_import) ---
# Doit être IDENTIQUE à chaque import pour qu'un même élève garde le même
# student_pseudo d'une année à l'autre (cf. contrainte students_pseudo_
# academic_year_unique). Si absent, repli sur data/artifacts/.salt à la
# racine du dépôt (cohérent avec les imports déjà chargés par le loader CLI
# sur cette même machine) — voir .env.example à la racine pour le détail.
# En production (Render), il n'existe pas de disque persistant entre deploys :
# cette variable DOIT être définie, sinon un redeploy change le sel et casse
# la stabilité des student_pseudo d'une année à l'autre.
MASSAR_SALT=

# --- CORS (app/main.py) ---
# Une ou plusieurs origines exactes séparées par des virgules (ex. domaine de
# prod Vercel + domaines de preview), jamais "*" : cet endpoint écrit des
# données réelles d'élèves. Si absent, aucune origine n'est autorisée (échec
# fermé), pas un repli permissif.
FRONTEND_ORIGIN=
